{
  "name": "hivekitchen",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@hivekitchen/web",
    "dev:api": "turbo run dev --filter=@hivekitchen/api",
    "dev:marketing": "turbo run dev --filter=@hivekitchen/marketing",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "contracts:check": "tsx packages/contracts/scripts/check.ts",
    "tools:check": "tsx apps/api/scripts/check-tool-manifest.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "seed:dev": "tsx test/helpers/seed-dev.ts",
    "seed:reset": "tsx test/helpers/seed-dev.ts --reset"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "^4.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "author": "Shree Menon",
  "license": "ISC"
}
