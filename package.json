{
  "name": "hivekitchen",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@hivekitchen/web",
    "dev:api": "turbo run dev --filter=@hivekitchen/api",
    "dev:marketing": "turbo run dev --filter=@hivekitchen/marketing",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "contracts:check": "tsx packages/contracts/scripts/check.ts",
    "tools:check": "tsx apps/api/scripts/check-tool-manifest.ts",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push --linked",
    "supabase:diff": "supabase db diff --linked",
    "supabase:status": "supabase projects list",
    "seed:dev": "tsx test/helpers/seed-dev.ts",
    "seed:reset": "tsx test/helpers/seed-dev.ts --reset"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@astrojs/check>typescript": "^6",
        "tsconfck>typescript": "^6"
      }
    },
    "patchedDependencies": {
      "fastify-type-provider-zod@4.0.2": "patches/fastify-type-provider-zod@4.0.2.patch"
    }
  },
  "author": "Shree Menon",
  "license": "ISC"
}
