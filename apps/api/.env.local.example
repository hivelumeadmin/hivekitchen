# apps/api environment — DEV ONLY (gitignored as apps/api/.env.local).
# Zod-validated parsing in Story 1.6 (apps/api/src/common/env.ts).
# Never commit real keys. Values below are sanitized placeholders.

# ---- Runtime ---------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ---- Supabase (DB + Auth + Storage + Vault) --------------------------
# HiveKitchen ALWAYS targets the Supabase cloud project — there is no local
# stack. Get these values from the cloud dashboard:
#   Settings → API → Project URL  →  SUPABASE_URL
#   Settings → API → service_role key  →  SUPABASE_SERVICE_ROLE_KEY (server-only, never ship to web)
#   Settings → API → anon public key  →  SUPABASE_ANON_KEY (safe to ship)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-cloud-project-service-role-key
SUPABASE_ANON_KEY=replace-with-cloud-project-anon-key

# ---- Supabase OAuth providers (read by supabase/config.toml + auth.service) -
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=replace-with-google-oauth-secret
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=replace-with-apple-oauth-client-id
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=replace-with-apple-oauth-secret

# ---- Web app base URL (used to build OAuth redirect_to + cookie Domain) ----
WEB_BASE_URL=http://localhost:5173

# ---- OpenAI (Agents SDK) ---------------------------------------------
OPENAI_API_KEY=sk-replace-with-dev-key

# ---- ElevenLabs (voice token + webhook ingest + custom LLM) ----------
ELEVENLABS_API_KEY=replace-with-dev-key
ELEVENLABS_WEBHOOK_SECRET=replace-with-hmac-secret
ELEVENLABS_AGENT_ID=replace-with-elevenlabs-agent-id
ELEVENLABS_CUSTOM_LLM_SECRET=replace-with-32-char-min-bearer-secret-for-llm-endpoint

# ---- Stripe (billing + webhook) --------------------------------------
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

# ---- SendGrid (Lunch Link email delivery) ----------------------------
SENDGRID_API_KEY=SG.replace

# ---- Twilio (Lunch Link SMS/WhatsApp delivery) -----------------------
TWILIO_ACCOUNT_SID=ACreplace
TWILIO_AUTH_TOKEN=replace

# ---- Redis (cache + BullMQ + SSE resume log) -------------------------
REDIS_URL=redis://127.0.0.1:6379

# ---- Auth (JWT signing — rotated out of .env.local in staging/prod) --
JWT_SECRET=replace-with-32-byte-random-dev-only-secret

# ---- Observability (OpenTelemetry → Grafana Cloud in staging/prod) ---
# Leave empty in dev; Pino writes to stdout per architecture §5.7.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
