{
  "name": "@hivekitchen/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "tools:check": "tsx scripts/check-tool-manifest.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.0.0",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^9",
    "@fastify/sensible": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@hivekitchen/contracts": "workspace:*",
    "@hivekitchen/types": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@sendgrid/mail": "^8.0.0",
    "@supabase/supabase-js": "^2.0.0",
    "bullmq": "^5.0.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "fastify-sse-v2": "^4.2.2",
    "fastify-type-provider-zod": "4.0.2",
    "ioredis": "^5.0.0",
    "openai": "^4.0.0",
    "pino": "^9.6.0",
    "stripe": "^22.1.0",
    "twilio": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@hivekitchen/eslint-config": "workspace:*",
    "@hivekitchen/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
