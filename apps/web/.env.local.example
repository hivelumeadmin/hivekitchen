# apps/web environment — DEV ONLY (gitignored as apps/web/.env.local).
# Vite exposes only VITE_* vars to the client bundle; every var here is
# safe-for-browser by construction.

VITE_API_BASE_URL=http://localhost:3001
VITE_API_WS_URL=ws://localhost:3001
VITE_SSE_BASE_URL=http://localhost:3001

# Used by the purpose-limited Supabase JS client in src/lib/supabase-client.ts
# to initiate OAuth redirects only — no DB queries or password sign-in.
# These point at the Supabase CLOUD project — there is no local stack.
# Get from cloud dashboard: Settings → API → Project URL / anon public key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-cloud-project-anon-key
